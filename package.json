{
  "name": "band-availability-system",
  "version": "2.0.0",
  "description": "Modern worship team availability tracking with PWA features",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --no-deprecation server/server.js",
    "dev": "node dev-start.js",
    "dev:api": "NODE_ENV=development node server/server.js",
    "dev:frontend": "cd next-frontend && npm run dev",
    "build": "npm run build:frontend && npm install --omit=dev",
    "build:frontend": "cd next-frontend && npm install && npm run build",
    "test": "node test/run-tests.js",
    "clean": "cd next-frontend && rm -rf .next node_modules",
    "postinstall": "cd next-frontend && npm install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.19.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "worship",
    "availability",
    "planning-center",
    "pwa",
    "supabase"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/band-availability.git"
  }
}
